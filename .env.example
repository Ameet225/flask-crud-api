# Flask Environment Configuration
# Copy this file to .env and update values as needed for your environment

# Flask environment: development, testing, or production
FLASK_ENV=development

# Flask host and port configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Database URL (optional, uses SQLite by default)
# DATABASE_URL=sqlite:///./instance/app.db

# For production with PostgreSQL example:
# DATABASE_URL=postgresql://username:password@localhost:5432/flask_crud_api
